# ============================================================
# Enterprise Calendar Sync — Environment Configuration
# ============================================================
# COPY this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=4400
HOST=localhost
API_BASE_URL=http://localhost:4400

# ---- Database ----
# Local dev: a SEPARATE database called "calendarsync_app" on your local Postgres.
# Production: Supabase (recommended) — see SETUP.md section 7b for the two URLs.
#
# DATABASE_URL = pooled connection (PgBouncer, port 6543) — used at runtime
# DIRECT_URL   = direct connection (port 5432) — used by prisma migrate
# For local Postgres both can be the same value.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/calendarsync_app
DIRECT_URL=postgresql://postgres:your_password@localhost:5432/calendarsync_app

# ---- Redis (for queues & caching) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Encryption (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=
ENCRYPTION_IV_LENGTH=16

# ---- JWT ----
JWT_SECRET=
JWT_EXPIRES_IN=24h
SESSION_SECRET=

# ---- Google OAuth 2.0 ----
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4400/auth/google/callback

# ---- Microsoft OAuth 2.0 ----
# Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:4400/auth/microsoft/callback

# ---- Webhook URLs (your public-facing URL for receiving webhooks) ----
# For local dev, use ngrok: https://ngrok.com
WEBHOOK_BASE_URL=https://your-domain.com
GOOGLE_WEBHOOK_URL=${WEBHOOK_BASE_URL}/webhooks/google
MICROSOFT_WEBHOOK_URL=${WEBHOOK_BASE_URL}/webhooks/microsoft

# ---- Security ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4400
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_SALT_ROUNDS=12

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=pretty

# ---- Admin Dashboard ----
ADMIN_DASHBOARD_URL=http://localhost:3000
