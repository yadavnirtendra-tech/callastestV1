{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@/types/*": ["./types/*"],
      "@/config/*": ["./config/*"],
      "@/database/*": ["./database/*"],
      "@/middleware/*": ["./middleware/*"],
      "@/auth/*": ["./auth/*"],
      "@/connectors/*": ["./connectors/*"],
      "@/sync/*": ["./sync/*"],
      "@/conflict/*": ["./conflict/*"],
      "@/notifications/*": ["./notifications/*"],
      "@/audit/*": ["./audit/*"],
      "@/queue/*": ["./queue/*"],
      "@/crypto/*": ["./crypto/*"],
      "@/routes/*": ["./routes/*"],
      "@/utils/*": ["./utils/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "admin-dashboard"]
}
