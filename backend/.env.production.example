# ============================================================
# PRODUCTION Environment Variables — Set these in Railway Dashboard
# ============================================================
# Go to: railway.app → Your Project → Variables tab
# Add each key below. Railway auto-provides DATABASE_URL and REDIS_URL
# when you add those plugins.
# ============================================================

# ---- Server (Railway sets PORT automatically) ----
NODE_ENV=production
API_BASE_URL=https://YOUR-APP-NAME.railway.app

# ---- Database (Railway PostgreSQL plugin provides this automatically) ----
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ---- Redis (Railway Redis plugin provides this automatically) ----
REDIS_URL=${{Redis.REDIS_URL}}

# ---- Encryption (REQUIRED — generate with the command below) ----
# Run once locally: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
ENCRYPTION_IV_LENGTH=16

# ---- JWT (REQUIRED — generate with the command below) ----
# Run once locally: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_128_char_hex_key_here
JWT_EXPIRES_IN=24h

# ---- Session ----
# Run once locally: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_64_char_hex_key_here

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://YOUR-APP-NAME.railway.app/auth/google/callback

# ---- Microsoft OAuth ----
MICROSOFT_CLIENT_ID=your_azure_app_id
MICROSOFT_CLIENT_SECRET=your_azure_secret_value
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://YOUR-APP-NAME.railway.app/auth/microsoft/callback

# ---- Webhooks (use Railway URL — permanent, no ngrok!) ----
WEBHOOK_BASE_URL=https://YOUR-APP-NAME.railway.app
GOOGLE_WEBHOOK_URL=https://YOUR-APP-NAME.railway.app/webhooks/google
MICROSOFT_WEBHOOK_URL=https://YOUR-APP-NAME.railway.app/webhooks/microsoft

# ---- Security ----
# Replace YOUR-VERCEL-APP.vercel.app with your actual Vercel domain
ALLOWED_ORIGINS=https://YOUR-VERCEL-APP.vercel.app,https://YOUR-APP-NAME.railway.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_SALT_ROUNDS=12

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=json

# ---- Admin Dashboard ----
ADMIN_DASHBOARD_URL=https://YOUR-VERCEL-APP.vercel.app
